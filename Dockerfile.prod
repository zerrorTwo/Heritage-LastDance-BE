FROM node:18-alpine

WORKDIR /app

COPY package*.json ./
RUN npm ci --production

COPY dist ./dist
COPY config.yaml ./

RUN addgroup -g 1001 -S nodejs && \
    adduser -S nodejs -u 1001 && \
    chown -R nodejs:nodejs /app/dist /app/config.yaml

USER nodejs

EXPOSE 3000

CMD ["node", "dist/main.js"]
