NODE_ENV=local
# If you run with docker-compose, you can override these as needed.

# App DB connection (used by src/config/database.ts)
HOST=mysql
PORT_DB=3306
USERNAME=heritage
PASSWORD=heritage_pass
NAME=heritage_db

# MySQL container init (used by docker-compose.yml)
DB_ROOT_PASS=rootpass
DB_NAME=heritage_db
DB_USER=heritage
DB_PASS=heritage_pass
