# Docker Compose + Local Dev
APP_PORT=3000
MAIL_CLIENT_PORT=1080
FILE_DRIVER=local

# Docker postgres
DATABASE_TYPE=postgres
DATABASE_HOST=postgres
DATABASE_PORT=5432
POSTGRES_HOST_PORT=5433
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=123456
DATABASE_NAME=heritage
DATABASE_SYNCHRONIZE=true
DATABASE_SSL_ENABLED=false
DATABASE_MAX_CONNECTIONS=20

# Auth
JWT_SECRET=change_me_jwt_secret

# Google OAuth
GOOGLE_CLIENT_SECRET=

# Resend (Email)
RESEND_API_KEY=

# Cloudinary
CLOUDINARY_API_SECRET=

# Heritage AI Services
AI_SERVICE_TOKEN=

# DeepSeek AI (Mind Map)
DEEPSEEK_API_KEY=

# Docker maildev
MAIL_HOST=maildev
MAIL_PORT=1025
MAIL_USER=
MAIL_PASSWORD=
MAIL_IGNORE_TLS=true
MAIL_SECURE=false
MAIL_REQUIRE_TLS=false
MAIL_DEFAULT_EMAIL=noreply@heritage.dev
MAIL_DEFAULT_NAME=Heritage

# Neo4j
NEO4J_ENABLED=true
NEO4J_URI=
NEO4J_USERNAME=
NEO4J_PASSWORD=
NEO4J_DATABASE=neo4j
NEO4J_MAX_CONNECTION_POOL_SIZE=50
NEO4J_CONNECTION_ACQUISITION_TIMEOUT_MS=60000
NEO4J_CONNECTION_TIMEOUT_MS=30000
NEO4J_MAX_TRANSACTION_RETRY_TIME_MS=30000
