# Application
NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=aioz
DATABASE_PASS=aiozpass
DATABASE_NAME=aioz_map

# JWT
JWT_SECRET=change_me_jwt_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# Session
SESSION_TTL_HOURS=24
REFRESH_TOKEN_TTL_DAYS=7

# OTP
OTP_EXPIRE_MINUTES=5
OTP_RESEND_LIMIT_TTL_MINUTES=60
OTP_MAX_ATTEMPTS_PER_HOUR=5
OTP_MAX_RESEND_ATTEMPTS=5

# Reset Password
RESET_PASSWORD_TOKEN_TTL_MINUTES=15

# MetaMask
METAMASK_CHALLENGE_TTL_MINUTES=2

# Frontend
FRONTEND_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/v1/api/auth/google/callback

# Throttling
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Resend (Email)
RESEND_API_KEY=
RESEND_FROM=AIOZ STREAM <no-reply@yourdomain.com>

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Heritage AI Services
AI_SERVICE_URL=http://localhost:5055
AI_SERVICE_TOKEN=
AI_CHAT_MODE=search_only

# DeepSeek AI (Mind Map)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
